# ─────────────────────────────────────────
# .env — Anthony Kuiau Portfolio Bot Config
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to admin the bot
# Leave blank to allow anyone (not recommended for production)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Firebase ──
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Path to your Firebase service account key JSON
# Download from: Firebase Console → Project Settings → Service accounts
FIREBASE_SERVICE_ACCOUNT=./firebase/serviceAccountKey.json

# ── Site ──
# Used by the bot's "Preview Site" button
SITE_URL=https://yourdomain.com
